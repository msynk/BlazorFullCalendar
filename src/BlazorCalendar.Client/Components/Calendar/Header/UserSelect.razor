<div class="cal-user-select">
    <button class="cal-btn cal-btn-sm" @onclick="() => _open = !_open">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        @_selectedLabel
    </button>
    @if (_open)
    {
        <div class="cal-user-select-menu">
            <div class="cal-user-option @(State.SelectedUserId == "all" ? "active" : "")"
                 @onclick='() => Select("all")'>All Users</div>
            @foreach (var user in State.Users)
            {
                <div class="cal-user-option @(State.SelectedUserId == user.Id ? "active" : "")"
                     @onclick="() => Select(user.Id)">@user.Name</div>
            }
        </div>
    }
</div>

@code {
    [CascadingParameter] public CalendarState State { get; set; } = default!;
    private bool _open;

    private string _selectedLabel =>
        State.SelectedUserId == "all"
            ? "All Users"
            : State.Users.FirstOrDefault(u => u.Id == State.SelectedUserId)?.Name ?? "All Users";

    private void Select(string userId)
    {
        State.FilterByUser(userId);
        _open = false;
    }
}

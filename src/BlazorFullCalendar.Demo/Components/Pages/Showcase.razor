<!-- Hide Filters & Custom Filter UI -->
<section class="demo-showcase">
    <div class="demo-showcase-header">
        <div class="demo-showcase-badge" style="background:#fef3c7;color:#d97706;border:1px solid #fde68a;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            Custom Filters
        </div>
        <h2>External Filter UI</h2>
        <p>
            Set <code>HideFilters</code> to <code>true</code> to remove the built-in color and people dropdowns.
            Build your own filter UI and pass pre-filtered events to the calendar. This example adds a text search
            across event <code>Title</code> and <code>Description</code>.
        </p>
    </div>

    <div class="demo-showcase-grid">
        <div class="demo-showcase-card">
            <div class="demo-showcase-card-header">
                <span style="width:28px;height:28px;border-radius:8px;background:#fef3c7;color:#d97706;display:inline-flex;align-items:center;justify-content:center;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                </span>
                <h3>HideFilters Option</h3>
            </div>
            <div class="demo-showcase-card-body">
                <p>
                    When <code>HideFilters = true</code>, the built-in color and people dropdowns are removed
                    from the header. You provide your own filter UI and supply already-filtered events.
                </p>
                <div class="demo-code-block" style="margin:0;">
                    <div class="demo-code-label">Hide built-in filters</div>
                    <pre><span class="tag">&lt;BlazorFullCalendar</span>
    <span class="attr">Events</span>=<span class="str">"filteredEvents"</span>
    <span class="attr">HideFilters</span>=<span class="str">"true"</span> <span class="tag">/&gt;</span></pre>
                </div>
            </div>
        </div>

        <div class="demo-showcase-card">
            <div class="demo-showcase-card-header">
                <span style="width:28px;height:28px;border-radius:8px;background:#dbeafe;color:#3b82f6;display:inline-flex;align-items:center;justify-content:center;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </span>
                <h3>Text Search &amp; Custom Filters</h3>
            </div>
            <div class="demo-showcase-card-body">
                <p>
                    Filter events externally by any criteria &mdash; color, attendee, or free-text search across
                    <code>Title</code> and <code>Description</code>. Pass the filtered list to the calendar.
                </p>
                <div class="demo-code-block" style="margin:0;">
                    <div class="demo-code-label">External filtering</div>
                    <pre><span class="kw">@@code</span> {
    <span class="type">List&lt;BlazorFullCalendarEvent&gt;</span> all = ...;

    <span class="type">List&lt;BlazorFullCalendarEvent&gt;</span> Filtered =>
        all.Where(e =>
            e.Title.Contains(search) ||
            e.Description.Contains(search))
        .ToList();
}</pre>
                </div>
            </div>
        </div>
    </div>

    <div style="display:flex;flex-wrap:wrap;gap:12px;padding:0 24px 20px;align-items:end;">
        <div style="display:flex;flex-direction:column;gap:4px;flex:1;min-width:200px;">
            <label style="font-size:12px;font-weight:600;color:var(--demo-text-secondary);">Search</label>
            <div style="position:relative;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);opacity:0.4;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" placeholder="Search title or description..."
                       value="@_filterSearchText"
                       @oninput="OnFilterSearchInput"
                       style="width:100%;padding:8px 12px 8px 32px;border:1px solid var(--demo-border);border-radius:8px;font-size:13px;outline:none;background:var(--demo-bg);color:var(--demo-text);" />
            </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:4px;min-width:140px;">
            <label style="font-size:12px;font-weight:600;color:var(--demo-text-secondary);">Color</label>
            <select @onchange="OnFilterColorChange"
                    style="padding:8px 12px;border:1px solid var(--demo-border);border-radius:8px;font-size:13px;outline:none;background:var(--demo-bg);color:var(--demo-text);cursor:pointer;">
                <option value="">All Colors</option>
                @foreach (var c in Enum.GetValues<BlazorFullCalendarEventColor>())
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>

        <div style="display:flex;flex-direction:column;gap:4px;min-width:160px;">
            <label style="font-size:12px;font-weight:600;color:var(--demo-text-secondary);">Person</label>
            <select @onchange="OnFilterAttendeeChange"
                    style="padding:8px 12px;border:1px solid var(--demo-border);border-radius:8px;font-size:13px;outline:none;background:var(--demo-bg);color:var(--demo-text);cursor:pointer;">
                <option value="">All People</option>
                @foreach (var a in _filterDistinctAttendees)
                {
                    <option value="@a.Id">@a.FullName</option>
                }
            </select>
        </div>

        @if (_filterSearchText.Length > 0 || _filterSelectedColor.HasValue || !string.IsNullOrEmpty(_filterSelectedAttendeeId))
        {
            <button type="button" class="demo-btn demo-btn-secondary" style="padding:8px 16px;font-size:12px;white-space:nowrap;" @onclick="ClearCustomFilters">
                Clear Filters
            </button>
        }
    </div>

    @if (_filterSearchText.Length > 0 || _filterSelectedColor.HasValue || !string.IsNullOrEmpty(_filterSelectedAttendeeId))
    {
        <div style="padding:0 24px 12px;">
            <span style="font-size:12px;color:var(--demo-text-secondary);">
                Showing @_filterDemoEventsFiltered.Count of @_filterDemoEventsAll.Count events
            </span>
        </div>
    }

    <div class="demo-showcase-calendar">
        <BlazorFullCalendar Events="_filterDemoEventsFiltered"
                            HideFilters="true"
                            OnChange="HandleCalendarChange" />
    </div>
</section>

<footer class="demo-footer">
    <p>
        Blazor Calendar &mdash; Inspired by
        <a href="https://github.com/yassir-jeraidi/full-calendar" target="_blank">yassir-jeraidi/full-calendar</a>
    </p>
</footer>

@code {
    private sealed record EventMeta(string? Icon, string? Priority, string? Room);

    private static readonly List<BlazorFullCalendarEvent> _templateDemoEvents = CreateTemplateDemoEvents();
    private readonly List<BlazorFullCalendarEvent> _handlerDemoEvents = DemoSampleData.CreateEvents();
    private int _nextId = 1000;

    private BlazorFullCalendarEvent? _clickedEvent;
    private string? _clickedEventOriginalId;
    private string? _editError;
    private BlazorFullCalendarEvent? _draftEvent;
    private string? _addEditError;
    private BlazorFullCalendarDateChangeEventArgs? _lastDateChange;

    private static List<BlazorFullCalendarEvent> CreateTemplateDemoEvents()
    {
        var today = DateTime.Today;
        return
        [
            new() { Id = "t1", Title = "Sprint Review",        Description = "Demo features to stakeholders.",     StartDate = today.AddHours(9),              EndDate = today.AddHours(10),            Color = BlazorFullCalendarEventColor.Blue,   Attendees = [new() { FirstName = "Alice", LastName = "J", Id = "1" }], Data = new EventMeta("🎯", "High", "Room A1") },
            new() { Id = "t2", Title = "Design Sync",          Description = "Review new dashboard mockups.",       StartDate = today.AddHours(10).AddMinutes(30), EndDate = today.AddHours(11).AddMinutes(30), Color = BlazorFullCalendarEventColor.Purple, Attendees = [new() { FirstName = "Bob", LastName = "S", Id = "2" }], Data = new EventMeta("🎨", null, "Studio B") },
            new() { Id = "t3", Title = "Prod Incident Review", Description = "Postmortem for last week's outage.", StartDate = today.AddHours(13),             EndDate = today.AddHours(14),            Color = BlazorFullCalendarEventColor.Red,    Attendees = [new() { FirstName = "Carol", LastName = "D", Id = "3" }, new() { FirstName = "David", LastName = "L", Id = "4" }], Data = new EventMeta("🔥", "High", null) },
            new() { Id = "t4", Title = "Lunch & Learn",        Description = "Intro to Blazor SSR.",               StartDate = today.AddHours(12),             EndDate = today.AddHours(13),            Color = BlazorFullCalendarEventColor.Green,  Attendees = [], Data = new EventMeta("📚", null, "Cafeteria") },
            new() { Id = "t5", Title = "Focus Block",          Description = "Deep work - no interruptions.",       StartDate = today.AddHours(14).AddMinutes(30), EndDate = today.AddHours(16),            Color = BlazorFullCalendarEventColor.Yellow, Attendees = [], Data = new EventMeta("🧘", null, null) },
            new() { Id = "t6", Title = "Client Call",          Description = "Quarterly business review.",          StartDate = today.AddHours(16),             EndDate = today.AddHours(17),            Color = BlazorFullCalendarEventColor.Orange, Attendees = [new() { FirstName = "Eva", LastName = "M", Id = "5" }], Data = new EventMeta("📞", "High", "Board Room") },
            new() { Id = "t7", Title = "Team Offsite",         Description = "Strategy planning at the lake house.",StartDate = today.AddDays(2).AddHours(9),   EndDate = today.AddDays(4).AddHours(17), Color = BlazorFullCalendarEventColor.Purple, Attendees = [new() { FirstName = "Alice", LastName = "J", Id = "1" }, new() { FirstName = "Bob", LastName = "S", Id = "2" }], Data = new EventMeta("🏕️", null, null) },
            new() { Id = "t8", Title = "Release Day",          Description = "v3.0 go-live.",                       StartDate = today.AddDays(5).AddHours(10),  EndDate = today.AddDays(5).AddHours(12), Color = BlazorFullCalendarEventColor.Green,  Attendees = [], Data = new EventMeta("🚀", "High", null) },
            new() { Id = "t9", Title = "Workshop",             Description = "Component architecture deep dive.",   StartDate = today.AddDays(1).AddHours(10),  EndDate = today.AddDays(1).AddHours(12), Color = BlazorFullCalendarEventColor.Blue,   Attendees = [new() { FirstName = "Frank", LastName = "C", Id = "6" }], Data = new EventMeta("🛠️", null, "Lab 3") },
            new() { Id = "t10", Title = "All Hands",           Description = "Company-wide monthly meeting.",       StartDate = today.AddDays(1).AddHours(14),  EndDate = today.AddDays(1).AddHours(15), Color = BlazorFullCalendarEventColor.Orange, Attendees = [], Data = new EventMeta("📣", null, "Main Hall") },
        ];
    }

    private void OnCustomEventClick(BlazorFullCalendarEvent ev)
    {
        _clickedEventOriginalId = ev.Id;
        _clickedEvent = new BlazorFullCalendarEvent
        {
            Id = ev.Id,
            Title = ev.Title,
            Description = ev.Description,
            StartDate = ev.StartDate,
            EndDate = ev.EndDate,
            Color = ev.Color,
            Attendees = [.. ev.Attendees],
            Data = ev.Data
        };
        _editError = null;
    }

    private void OnCustomAddClick(BlazorFullCalendarEvent? ev)
    {
        _draftEvent = ev;
    }

    private void CloseEventModal()
    {
        _clickedEvent = null;
        _clickedEventOriginalId = null;
        _editError = null;
    }

    private void SaveClickedEvent()
    {
        if (_clickedEvent is null) return;

        if (string.IsNullOrWhiteSpace(_clickedEvent.Title))
        {
            _editError = "Title is required.";
            return;
        }

        if (_clickedEvent.EndDate <= _clickedEvent.StartDate)
        {
            _editError = "End date must be after start date.";
            return;
        }

        var idx = _handlerDemoEvents.FindIndex(e => e.Id == _clickedEventOriginalId);
        if (idx >= 0)
        {
            _handlerDemoEvents[idx] = _clickedEvent;
        }

        _clickedEvent = null;
        _clickedEventOriginalId = null;
        _editError = null;
    }

    private void CloseAddEditModal()
    {
        _draftEvent = null;
        _addEditError = null;
    }

    private void SaveDraftEvent()
    {
        if (_draftEvent is null) return;

        if (string.IsNullOrWhiteSpace(_draftEvent.Title))
        {
            _addEditError = "Title is required.";
            return;
        }

        if (_draftEvent.EndDate <= _draftEvent.StartDate)
        {
            _addEditError = "End date must be after start date.";
            return;
        }

        _draftEvent.Id = (++_nextId).ToString();
        _handlerDemoEvents.Add(_draftEvent);

        _draftEvent = null;
        _addEditError = null;
    }

    // --- Options demo ---
    private readonly List<BlazorFullCalendarEvent> _optionsDemoEvents = DemoSampleData.CreateEvents();
    private BlazorFullCalendarOptions _calendarOptions = new();
    private bool _optionsHideSettings;
    private bool _optionsDarkMode;
    private bool _options24Hour = true;
    private bool _optionsDotBadge;
    private int _optionsStartHour = 8;

    private void RebuildOptions() => _calendarOptions = new BlazorFullCalendarOptions
    {
        IsDarkMode = _optionsDarkMode,
        Use24HourFormat = _options24Hour,
        BadgeVariant = _optionsDotBadge ? BlazorFullCalendarBadgeVariant.Dot : BlazorFullCalendarBadgeVariant.Colored,
        StartOfDayHour = _optionsStartHour,
    };

    private void ToggleOptionsDarkMode(ChangeEventArgs e) { _optionsDarkMode = (bool)e.Value!; RebuildOptions(); }
    private void ToggleOptions24Hour(ChangeEventArgs e) { _options24Hour = (bool)e.Value!; RebuildOptions(); }
    private void ToggleOptionsDotBadge(ChangeEventArgs e) { _optionsDotBadge = (bool)e.Value!; RebuildOptions(); }
    private void ToggleOptionsHideSettings(ChangeEventArgs e) { _optionsHideSettings = (bool)e.Value!; }

    private void OnOptionsStartHourChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val) && val is >= 0 and <= 16)
        {
            _optionsStartHour = val;
            RebuildOptions();
        }
    }

    private Task HandleCalendarChange(BlazorFullCalendarChangeEventArgs args) => Task.CompletedTask;

    private void OnDateChange(BlazorFullCalendarDateChangeEventArgs args) => _lastDateChange = args;

    // --- Hide filters / custom filter UI demo ---
    private readonly List<BlazorFullCalendarEvent> _filterDemoEventsAll = DemoSampleData.CreateEvents();
    private List<BlazorFullCalendarEvent> _filterDemoEventsFiltered = [];


    private string _filterSearchText = string.Empty;
    private BlazorFullCalendarEventColor? _filterSelectedColor;
    private string? _filterSelectedAttendeeId;
    private List<BlazorFullCalendarAttendee> _filterDistinctAttendees = [];

    protected override void OnInitialized()
    {
        _filterDistinctAttendees = _filterDemoEventsAll
            .SelectMany(e => e.Attendees)
            .GroupBy(a => a.Id ?? a.FullName)
            .Select(g => g.First())
            .OrderBy(a => a.FullName, StringComparer.CurrentCultureIgnoreCase)
            .ToList();

        ApplyCustomFilters();
    }

    private void OnFilterSearchInput(ChangeEventArgs e)
    {
        _filterSearchText = e.Value?.ToString() ?? string.Empty;
        ApplyCustomFilters();
    }

    private void OnFilterColorChange(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        _filterSelectedColor = !string.IsNullOrWhiteSpace(val) && Enum.TryParse<BlazorFullCalendarEventColor>(val, out var c) ? c : null;
        ApplyCustomFilters();
    }

    private void OnFilterAttendeeChange(ChangeEventArgs e)
    {
        _filterSelectedAttendeeId = string.IsNullOrWhiteSpace(e.Value?.ToString()) ? null : e.Value!.ToString();
        ApplyCustomFilters();
    }

    private void ClearCustomFilters()
    {
        _filterSearchText = string.Empty;
        _filterSelectedColor = null;
        _filterSelectedAttendeeId = null;
        ApplyCustomFilters();
    }

    private void ApplyCustomFilters()
    {
        var result = _filterDemoEventsAll.AsEnumerable();

        if (_filterSearchText.Length > 0)
        {
            result = result.Where(e =>
                e.Title.Contains(_filterSearchText, StringComparison.OrdinalIgnoreCase) ||
                e.Description.Contains(_filterSearchText, StringComparison.OrdinalIgnoreCase));
        }

        if (_filterSelectedColor.HasValue)
            result = result.Where(e => e.Color == _filterSelectedColor.Value);

        if (!string.IsNullOrEmpty(_filterSelectedAttendeeId))
            result = result.Where(e => e.Attendees.Any(a => a.Id == _filterSelectedAttendeeId));

        _filterDemoEventsFiltered = result.ToList();
    }
}

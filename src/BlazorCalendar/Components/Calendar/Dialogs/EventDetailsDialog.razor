<div class="cal-overlay" @onclick="OnClose">
    <div class="cal-dialog" @onclick:stopPropagation="true">
        <div class="cal-dialog-header">
            <h3>@Event.Title</h3>
        </div>
        <div class="cal-dialog-body">
            <div class="cal-event-detail-row">
                <svg class="cal-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <div>
                    <div class="cal-event-detail-label">Responsible</div>
                    <div class="cal-event-detail-value">@Event.User.Name</div>
                </div>
            </div>
            <div class="cal-event-detail-row">
                <svg class="cal-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <div>
                    <div class="cal-event-detail-label">Start Date</div>
                    <div class="cal-event-detail-value">
                        @Event.StartDate.ToString("dddd dd MMMM") at @CalendarHelpers.FormatTime(Event.StartDate, State.Use24HourFormat)
                    </div>
                </div>
            </div>
            <div class="cal-event-detail-row">
                <svg class="cal-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <div>
                    <div class="cal-event-detail-label">End Date</div>
                    <div class="cal-event-detail-value">
                        @Event.EndDate.ToString("dddd dd MMMM") at @CalendarHelpers.FormatTime(Event.EndDate, State.Use24HourFormat)
                    </div>
                </div>
            </div>
            <div class="cal-event-detail-row">
                <svg class="cal-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                <div>
                    <div class="cal-event-detail-label">Description</div>
                    <div class="cal-event-detail-value">@Event.Description</div>
                </div>
            </div>
        </div>
        <div class="cal-dialog-footer">
            <button class="cal-btn" @onclick="Edit">Edit</button>
            <button class="cal-btn cal-btn-danger" @onclick="Delete">Delete</button>
        </div>
    </div>
</div>

@if (_showEdit)
{
    <AddEditEventDialog ExistingEvent="Event" OnClose="OnEditClose" />
}

@code {
    [CascadingParameter] public CalendarState State { get; set; } = default!;
    [Parameter] public CalendarEvent Event { get; set; } = default!;
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _showEdit;

    private void Edit() => _showEdit = true;

    private void OnEditClose()
    {
        _showEdit = false;
        OnClose.InvokeAsync();
    }

    private void Delete()
    {
        State.RemoveEvent(Event.Id);
        OnClose.InvokeAsync();
    }
}

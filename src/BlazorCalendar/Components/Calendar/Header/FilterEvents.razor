<select class="cal-filter-select" @onchange="HandleColorChange" value="@SelectedColorValue" aria-label="Filter events by color">
    <option value="">All colors</option>
    @foreach (var color in Enum.GetValues<EventColor>())
    {
        <option value="@color">@color</option>
    }
</select>

@code {
    [CascadingParameter] public CalendarState State { get; set; } = default!;

    private string SelectedColorValue => State.SelectedColors.Count == 1
        ? State.SelectedColors[0].ToString()
        : string.Empty;

    private void HandleColorChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(value))
        {
            State.SetColorFilter(null);
            return;
        }

        if (Enum.TryParse<EventColor>(value, out var selected))
            State.SetColorFilter(selected);
    }
}

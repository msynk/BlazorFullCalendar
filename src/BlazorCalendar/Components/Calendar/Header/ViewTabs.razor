<div class="cal-view-tabs">
    @foreach (var view in _views)
    {
        <button class="cal-view-tab @(State.View == view ? "active" : "")"
                @onclick="() => State.SetView(view)">
            @Texts.GetViewLabel(view)
        </button>
    }
</div>

@code {
    [CascadingParameter] public BlazorCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorCalendarTexts Texts { get; set; } = default!;

    private static readonly BlazorCalendarView[] _views = [
        BlazorCalendarView.Day, BlazorCalendarView.Week, BlazorCalendarView.Month,
        BlazorCalendarView.Year, BlazorCalendarView.Agenda
    ];
}

@{
    var positionClass = Position switch
    {
        "first" => "position-first",
        "middle" => "position-middle",
        "last" => "position-last",
        _ => ""
    };

    var isDotVariant = State.BadgeVariant == BadgeVariant.Dot;
    var colorClass = isDotVariant ? "dot-variant" : CalendarHelpers.GetColorCss(Event.Color);
    var showTitle = Position is "first" or "none";
    var showTime = Position is "last" or "none";
}

<div class="cal-event-badge @colorClass @positionClass"
     style="@MarginStyle"
     draggable="true"
     @ondragstart="OnDragStart"
     @ondragend="OnDragEnd"
     @onclick="() => ShowDetails = true"
     @onclick:stopPropagation="true">

    <div style="display:flex;align-items:center;gap:4px;overflow:hidden;">
        @if (isDotVariant && Position is not "middle" and not "last")
        {
            <EventBullet Color="Event.Color" />
        }
        @if (showTitle)
        {
            <span class="cal-event-badge-title">@Event.Title</span>
        }
    </div>

    @if (showTime)
    {
        <span class="cal-event-badge-time">@CalendarHelpers.FormatTime(Event.StartDate, State.Use24HourFormat)</span>
    }
</div>

@if (ShowDetails)
{
    <EventDetailsDialog Event="Event" OnClose="() => ShowDetails = false" />
}

@code {
    [CascadingParameter] public CalendarState State { get; set; } = default!;
    [Parameter] public CalendarEvent Event { get; set; } = default!;
    [Parameter] public DateTime CellDate { get; set; }
    [Parameter] public string Position { get; set; } = "none";

    private bool ShowDetails;

    private string MarginStyle => Position switch
    {
        "first" => "margin-left:2px;margin-right:0;",
        "middle" => "margin:0;",
        "last" => "margin-left:0;margin-right:2px;",
        _ => "margin:0 2px;"
    };

    private void OnDragStart() => State.StartDrag(Event);
    private void OnDragEnd() => State.EndDrag();
}

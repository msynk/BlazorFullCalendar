@inject IJSRuntime JS

@{
    var weekStart = CalendarHelpers.StartOfWeek(State.SelectedDate);
    var weekDays = Enumerable.Range(0, 7).Select(i => weekStart.AddDays(i)).ToArray();
}

<div class="cal-week-layout">
    <div class="cal-week-mobile-warning">
        Weekly view is not recommended on smaller devices. Please switch to a desktop device or use the daily view instead.
    </div>

    <WeekViewMultiDayEventsRow MultiDayEvents="MultiDayEvents" Date="State.SelectedDate" />

    <div class="cal-week-header">
        <div class="cal-week-header-time"></div>
        @foreach (var day in weekDays)
        {
            var isToday = day.Date == DateTime.Today;
            <div class="cal-week-header-day">
                <span class="cal-week-header-day-name">@day.ToString("ddd", System.Globalization.CultureInfo.InvariantCulture)</span>
                <span class="cal-week-header-day-num @(isToday ? "today" : "")">@day.Day</span>
            </div>
        }
    </div>

    <div id="cal-week-timegrid-scroll" class="cal-timegrid-wrapper">
        <TimeColumn />
        <div class="cal-timegrid-days">
            @foreach (var day in weekDays)
            {
                var d = day;
                var dayEvents = SingleDayEvents.Where(e =>
                    e.StartDate.Date == d.Date || e.EndDate.Date == d.Date).ToList();
                var grouped = CalendarHelpers.GroupEvents(dayEvents);

                <div class="cal-week-day-col">
                    @for (int h = 0; h < 24; h++)
                    {
                        var hour = h;
                        <div class="cal-hour-row cal-droppable"
                             @ondragover:preventDefault="true"
                             @ondrop="() => OnDrop(d, hour, 0)"
                             @onclick="() => OnHourClick(d, hour)">
                            @if (h > 0)
                            {
                                <div style="position:absolute;top:0;left:0;right:0;border-top:1px solid var(--cal-border);"></div>
                            }
                            <div class="cal-hour-row-half cal-droppable"
                                 @ondragover:preventDefault="true"
                                 @ondrop="() => OnDrop(d, hour, 30)"></div>
                        </div>
                    }

                    <RenderGroupedEvents GroupedEvents="grouped" Day="d" />

                    @if (d.Date == DateTime.Today)
                    {
                        <CalendarTimeline />
                    }
                </div>
            }
        </div>
    </div>
</div>

@if (_showAddDialog)
{
    <AddEditEventDialog StartDate="_addDate" StartHour="_addHour" OnClose="() => _showAddDialog = false" />
}

@code {
    [CascadingParameter] public CalendarState State { get; set; } = default!;
    [Parameter] public List<CalendarEvent> SingleDayEvents { get; set; } = [];
    [Parameter] public List<CalendarEvent> MultiDayEvents { get; set; } = [];

    private string? _timeGridScrollSignature;

    private bool _showAddDialog;
    private DateTime _addDate;
    private int _addHour;

    private void OnHourClick(DateTime day, int hour)
    {
        _addDate = day;
        _addHour = hour;
        _showAddDialog = true;
    }

    private void OnDrop(DateTime day, int hour, int minute)
    {
        State.HandleDrop(day, hour, minute);
    }

    private string BuildTimeGridScrollSignature() =>
        $"{State.SelectedDate:yyyy-MM-dd}|{State.StartOfDayHour}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var sig = BuildTimeGridScrollSignature();
        if (sig == _timeGridScrollSignature)
            return;

        if (await TimeGridScrollInterop.TryScrollToStartOfDayAsync(
                JS,
                "cal-week-timegrid-scroll",
                State.StartOfDayHour))
            _timeGridScrollSignature = sig;
    }
}

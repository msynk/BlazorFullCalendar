@page "/demo"
@rendermode InteractiveServer

<PageTitle>Live Demo - Blazor Calendar</PageTitle>

<div style="display:flex;flex-direction:column;height:calc(100vh - 56px);">
    <div style="padding:12px 24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;border-bottom:1px solid var(--demo-border);">
        <div>
            <h1 style="font-size:18px;font-weight:700;margin:0;">Live Demo</h1>
            <p style="font-size:12px;color:var(--demo-text-secondary);margin:0;">
                Create events, switch views, drag &amp; drop, toggle settings.
            </p>
        </div>

        <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
            <button type="button"
                    style="font-size:13px;padding:5px 10px;border:1px solid var(--demo-border);border-radius:6px;background:var(--demo-bg);color:var(--demo-text);cursor:pointer;outline:none;"
                    @onclick="ToggleRecentChangesPanel"
                    aria-expanded="@_recentChangesPanelVisible"
                    title="@(_recentChangesPanelVisible ? "Hide the recent changes sidebar" : "Show the recent changes sidebar")">
                @(_recentChangesPanelVisible ? "Hide recent changes" : "Show recent changes")
            </button>
            <!-- Culture selector -->
            <div style="display:flex;align-items:center;gap:6px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--demo-text-secondary);flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                <select style="font-size:13px;padding:5px 8px;border:1px solid var(--demo-border);border-radius:6px;background:var(--demo-bg);color:var(--demo-text);cursor:pointer;outline:none;"
                        @bind="_selectedCultureName">
                    @foreach (var opt in _cultureOptions)
                    {
                        <option value="@opt.Name">@opt.Label</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div style="flex:1;padding:16px 24px 24px;min-height:0;display:grid;grid-template-columns:@(_recentChangesPanelVisible ? "minmax(0,1fr) 320px" : "minmax(0,1fr)");gap:16px;">
        <div style="height:100%;border:1px solid var(--demo-border);border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.06);">
            <BlazorCalendar Events="_demoEvents"
                            CultureName="@_selectedCultureName"
                            Texts="@SelectedTexts"
                            OnChange="HandleCalendarChange" />
        </div>
        @if (_recentChangesPanelVisible)
        {
        <aside style="border:1px solid var(--demo-border);border-radius:12px;background:var(--demo-bg);padding:12px;overflow:auto;">
            <h3 style="margin:0 0 8px 0;font-size:14px;">Recent Changes</h3>
            @if (_recentChanges.Count == 0)
            {
                <p style="margin:0;color:var(--demo-text-secondary);font-size:12px;">No event changes yet.</p>
            }
            else
            {
                <ul style="margin:0;padding-left:16px;display:flex;flex-direction:column;gap:8px;">
                    @foreach (var change in _recentChanges)
                    {
                        <li style="font-size:12px;line-height:1.35;">
                            <strong>@change.Kind</strong> via @change.Source<br />
                            <span>@change.Title</span><br />
                            <span style="color:var(--demo-text-secondary);">@change.AtLocal.ToString("yyyy-MM-dd HH:mm:ss")</span>
                        </li>
                    }
                </ul>
            }
        </aside>
        }
    </div>
</div>


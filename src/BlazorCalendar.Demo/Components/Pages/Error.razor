@page "/Error"
@inject IWebAssemblyHostEnvironment HostEnvironment

<PageTitle>Error</PageTitle>

<h1 style="color:#b91c1c;">Error.</h1>
<h2 style="color:#b91c1c;font-size:1.1rem;font-weight:600;">An error occurred while processing your request.</h2>

@if (HostEnvironment.IsDevelopment())
{
    <p>
        For more detail, open the browser developer tools console and check the
        <strong>Console</strong> and <strong>Network</strong> tabs.
    </p>
}

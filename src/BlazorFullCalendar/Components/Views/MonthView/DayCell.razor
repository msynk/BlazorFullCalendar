@namespace BlazorFullCalendar

@{
    var isToday = Cell.Date.Date == DateTime.Today;
    var cellEvents = BlazorFullCalendarHelpers.GetMonthCellEvents(Cell.Date, Events, EventPositions);
}

<div class="cal-month-cell @(!Cell.CurrentMonth ? "other-month" : "") cal-droppable"
     @ondragover="OnDragOver"
     @ondragover:preventDefault="true"
     @ondrop="OnDrop"
     @onclick="() => OnCellClick()">

    <div class="cal-month-cell-day @(isToday ? "today" : "")">@Cell.Day</div>
    <div class="cal-cell-add-hint cal-cell-add-hint-month" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        @Texts.AddEventHoverHint
    </div>

    <div class="cal-month-events">
        @for (int i = 0; i < 3; i++)
        {
            var pos = i;
            var item = cellEvents.FirstOrDefault(e => e.Position == pos);
            @if (item.Event != null)
            {
                var position = GetBadgePosition(item.Event, Cell.Date);
                <div class="cal-month-event-slot">
                    <MonthEventBadge Event="item.Event" CellDate="Cell.Date" Position="@position" OnSelected="ShowEventDetails" />
                </div>
            }
            else
            {
                <div class="cal-month-event-slot"></div>
            }
        }
    </div>

    @{
        var moreCount = cellEvents.Count - 3;
    }
    @if (Cell.CurrentMonth && moreCount > 0)
    {
        <div class="cal-month-more" @onclick="() => _showEventList = true" @onclick:stopPropagation="true">
            +@moreCount @Texts.MoreEventsSuffix
        </div>
    }
</div>

@if (_showEventList)
{
    <EventListDialog Date="Cell.Date" Events="cellEvents.Select(e => e.Event).ToList()" OnClose="() => _showEventList = false" />
}

@if (_showAddDialog)
{
    <AddEditEventDialog StartDate="Cell.Date" OnClose="() => _showAddDialog = false" />
}

@if (_selectedEvent != null)
{
    <EventDetailsDialog Event="_selectedEvent" OnClose="CloseEventDetails" />
}

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarTexts Texts { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarChangeNotifier Notifier { get; set; } = default!;
    [CascadingParameter(Name = "OnAddOrEditClick")] public EventCallback<BlazorFullCalendarEvent?> OnAddOrEditClick { get; set; }
    [Parameter] public BlazorFullCalendarCell Cell { get; set; } = default!;
    [Parameter] public List<BlazorFullCalendarEvent> Events { get; set; } = [];
    [Parameter] public Dictionary<string, int> EventPositions { get; set; } = new();

    private bool _showEventList;
    private bool _showAddDialog;
    private BlazorFullCalendarEvent? _selectedEvent;

    private void ShowEventDetails(BlazorFullCalendarEvent ev) => _selectedEvent = ev;
    private void CloseEventDetails() => _selectedEvent = null;

    private async Task OnCellClick()
    {
        State.SetSelectedDate(Cell.Date);
        if (OnAddOrEditClick.HasDelegate)
        {
            var draft = BlazorFullCalendarHelpers.CreateDraftEventForTimeSlot(
                Cell.Date,
                DateTime.Now.Hour);
            await OnAddOrEditClick.InvokeAsync(draft);
        }
        else
            _showAddDialog = true;
    }

    private string GetBadgePosition(BlazorFullCalendarEvent ev, DateTime cellDate)
    {
        if (ev.IsSingleDay) return "none";
        if (ev.StartDate.Date == cellDate.Date) return "first";
        if (ev.EndDate.Date == cellDate.Date) return "last";
        return "middle";
    }

    private void OnDragOver() { }

    private async Task OnDrop()
    {
        await Notifier.HandleDropAsync(Cell.Date);
    }
}


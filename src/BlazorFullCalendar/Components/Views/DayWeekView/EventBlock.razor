@namespace BlazorFullCalendar
@inject IJSRuntime JS
@implements IDisposable

@{
    var displayStart = _previewStart ?? Event.StartDate;
    var displayEnd = _previewEnd ?? Event.EndDate;
    var durationMin = (displayEnd - displayStart).TotalMinutes;
    var heightPx = (durationMin / 60.0) * BlazorFullCalendarHelpers.HourHeightPx;
    var isDotVariant = State.BadgeVariant == BlazorFullCalendarBadgeVariant.Dot;
    var colorClass = isDotVariant ? "dot-variant" : BlazorFullCalendarHelpers.GetColorCss(Event.Color);
    double translateYPx = 0;
    if (_isResizing && string.Equals(_resizeDirection, "top", StringComparison.Ordinal) && _resizeBaseEvent != null && _previewStart.HasValue)
        translateYPx = (displayStart - _resizeBaseEvent.StartDate).TotalMinutes / 60.0 * BlazorFullCalendarHelpers.HourHeightPx;
    var inv = System.Globalization.CultureInfo.InvariantCulture;
    var blockStyle = $"height:{heightPx.ToString("F0", inv)}px;transform:translateY({translateYPx.ToString("F2", inv)}px);";
    var resizeClasses = "";
    if (_isResizing)
    {
        resizeClasses = "cal-event-block-resizing";
        if (_resizeDirection is "top" or "bottom")
            resizeClasses += $" cal-resize-dir-{_resizeDirection}";
    }
}

<div class="cal-event-block @colorClass @(State.IsDragging ? "cal-event-block-pass-through" : "") @resizeClasses"
     style="@blockStyle"
     draggable="true"
     @ondragstart="OnDragStart"
     @ondragend="OnDragEnd"
     @onclick="OnClick"
     @onclick:stopPropagation="true">

    <div id="@_topHandleId"
         class="cal-resize-handle cal-resize-handle-top"
         @onpointerdown="OnResizeTopStart"
         @onpointerdown:preventDefault="true"
         @onpointerdown:stopPropagation="true"></div>

    <div style="display:flex;align-items:center;gap:4px;">
        @if (isDotVariant)
        {
            <EventBullet Color="Event.Color" />
        }
        <span class="cal-event-block-title">@Event.Title</span>
    </div>

    @if (durationMin > 25)
    {
        <div class="cal-event-block-time">
            @BlazorFullCalendarHelpers.FormatTime(displayStart, State.Use24HourFormat) - @BlazorFullCalendarHelpers.FormatTime(displayEnd, State.Use24HourFormat)
        </div>
    }

    <div id="@_bottomHandleId"
         class="cal-resize-handle cal-resize-handle-bottom"
         @onpointerdown="OnResizeBottomStart"
         @onpointerdown:preventDefault="true"
         @onpointerdown:stopPropagation="true"></div>

    @if (_isResizing)
    {
        <div class="cal-resize-preview" role="status" aria-live="polite" aria-label="@Texts.ResizePreviewAriaLabel">
            <svg class="cal-resize-preview-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span class="cal-resize-preview-time">@BlazorFullCalendarHelpers.FormatTime(displayStart, State.Use24HourFormat) â€“ @BlazorFullCalendarHelpers.FormatTime(displayEnd, State.Use24HourFormat)</span>
        </div>
    }
</div>

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarTexts Texts { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarChangeNotifier Notifier { get; set; } = default!;
    [Parameter] public BlazorFullCalendarEvent Event { get; set; } = default!;
    [Parameter] public EventCallback<BlazorFullCalendarEvent> OnSelected { get; set; }

    private readonly string _instanceId = Guid.NewGuid().ToString("N");
    private DotNetObjectReference<EventBlock>? _dotNetRef;
    private BlazorFullCalendarEvent? _resizeBaseEvent;
    private string? _resizeDirection;
    private DateTime? _previewStart;
    private DateTime? _previewEnd;
    private bool _resizeInitialized;
    private bool _isResizing;
    private DateTime _suppressClickUntilUtc;
    private string _topHandleId => $"cal-resize-top-{_instanceId}";
    private string _bottomHandleId => $"cal-resize-bottom-{_instanceId}";

    /// <summary>Minimum event length enforced by resize (minutes).</summary>
    private const int MinEventDurationMinutes = 30;

    /// <summary>
    /// Pointer movement below this (in minutes along the time axis) does not change start/end,
    /// so the edge does not jump as soon as the user presses the handle.
    /// </summary>
    private const int ResizeDeadZoneMinutes = MinEventDurationMinutes / 2;

    private void OnDragStart()
    {
        if (_isResizing)
            return;

        State.StartDrag(Event);
    }
    private void OnDragEnd() => State.EndDrag();

    private async Task OnClick()
    {
        if (DateTime.UtcNow <= _suppressClickUntilUtc || _isResizing)
            return;

        await OnSelected.InvokeAsync(Event);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_resizeInitialized)
            return;

        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("calendarInterop.initResize", _dotNetRef, _topHandleId, "top");
        await JS.InvokeVoidAsync("calendarInterop.initResize", _dotNetRef, _bottomHandleId, "bottom");
        _resizeInitialized = true;
    }

    [JSInvokable]
    public void OnResizeStart(string direction)
    {
        _isResizing = true;
        _resizeDirection = direction;
        _resizeBaseEvent = Event;
        _previewStart = null;
        _previewEnd = null;
        _suppressClickUntilUtc = DateTime.UtcNow.AddMilliseconds(300);
        State.EndDrag();
        _ = InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnResizeMove(string direction, int deltaMinutes)
    {
        if (!_isResizing || _resizeBaseEvent == null)
            return Task.CompletedTask;

        // Finger back at (or very near) the grab point â†’ show the original span again and cancel
        // any in-progress preview so the user can "undo" without releasing early.
        if (deltaMinutes == 0 || Math.Abs(deltaMinutes) <= ResizeDeadZoneMinutes)
        {
            if (_previewStart.HasValue || _previewEnd.HasValue)
            {
                _previewStart = null;
                _previewEnd = null;
                return InvokeAsync(StateHasChanged);
            }
            return Task.CompletedTask;
        }

        var effectiveDelta = deltaMinutes - Math.Sign(deltaMinutes) * ResizeDeadZoneMinutes;
        const int slotMinutes = MinEventDurationMinutes;
        var baseEvent = _resizeBaseEvent;

        var newStart = baseEvent.StartDate;
        var newEnd = baseEvent.EndDate;

        if (direction == "top")
        {
            var maxStart = baseEvent.EndDate.AddMinutes(-slotMinutes);
            var candidateStart = baseEvent.StartDate.AddMinutes(effectiveDelta);
            newStart = effectiveDelta > 0
                ? BlazorFullCalendarHelpers.CeilToMinuteInterval(candidateStart, slotMinutes)
                : BlazorFullCalendarHelpers.FloorToMinuteInterval(candidateStart, slotMinutes);
            if (newStart > maxStart)
                newStart = maxStart;
        }
        else
        {
            var minEnd = baseEvent.StartDate.AddMinutes(slotMinutes);
            var candidateEnd = baseEvent.EndDate.AddMinutes(effectiveDelta);
            newEnd = effectiveDelta > 0
                ? BlazorFullCalendarHelpers.CeilToMinuteInterval(candidateEnd, slotMinutes)
                : BlazorFullCalendarHelpers.FloorToMinuteInterval(candidateEnd, slotMinutes);
            if (newEnd < minEnd)
                newEnd = minEnd;
        }

        // Snapped range matches drag-start range â†’ treat as restored original (clear preview).
        if (newStart == baseEvent.StartDate && newEnd == baseEvent.EndDate)
        {
            if (_previewStart.HasValue || _previewEnd.HasValue)
            {
                _previewStart = null;
                _previewEnd = null;
                return InvokeAsync(StateHasChanged);
            }
            return Task.CompletedTask;
        }

        var curStart = _previewStart ?? baseEvent.StartDate;
        var curEnd = _previewEnd ?? baseEvent.EndDate;
        if (newStart == curStart && newEnd == curEnd)
            return Task.CompletedTask;

        _previewStart = newStart;
        _previewEnd = newEnd;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnResizeEnd()
    {
        try
        {
            if (_resizeBaseEvent != null && _previewStart.HasValue && _previewEnd.HasValue)
            {
                var s = _previewStart.Value;
                var e = _previewEnd.Value;
                if (s != _resizeBaseEvent.StartDate || e != _resizeBaseEvent.EndDate)
                {
                    var b = _resizeBaseEvent;
                    var updated = new BlazorFullCalendarEvent
                    {
                        Id = b.Id,
                        Title = b.Title,
                        Description = b.Description,
                        StartDate = s,
                        EndDate = e,
                        Color = b.Color,
                        Attendees = [.. b.Attendees]
                    };

                    State.UpdateEvent(updated);

                    await Notifier.NotifyAsync(new BlazorFullCalendarChangeEventArgs
                    {
                        Event = BlazorFullCalendarChangeNotifier.CloneEvent(updated),
                        OldEvent = BlazorFullCalendarChangeNotifier.CloneEvent(b),
                        Kind = BlazorFullCalendarChangeKind.Edit,
                        Source = BlazorFullCalendarChangeSource.Resize
                    });
                }
            }
        }
        finally
        {
            _previewStart = null;
            _previewEnd = null;
            _isResizing = false;
            _resizeBaseEvent = null;
            _resizeDirection = null;
            _suppressClickUntilUtc = DateTime.UtcNow.AddMilliseconds(300);
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnResizeTopStart() { }
    private void OnResizeBottomStart() { }

    public void Dispose() => _dotNetRef?.Dispose();
}


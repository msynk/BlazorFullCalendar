@namespace BlazorFullCalendar

<div class="bfc-overlay" @onclick="OnClose">
    <div class="bfc-dialog" @onclick:stopPropagation="true">
        <div class="bfc-dialog-header bfc-dialog-header-row">
            <h3>@Event.Title</h3>
            <button class="bfc-dialog-close-btn" @onclick="OnClose" aria-label="@Texts.CloseAriaLabel">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="bfc-dialog-body">
            <div class="bfc-event-detail-row">
                <span class="bfc-event-detail-swatch @BlazorFullCalendarHelpers.GetBgColorCss(Event.Color)" aria-hidden="true"></span>
                <div>
                    <div class="bfc-event-detail-label">@Texts.ColorLabel</div>
                    <div class="bfc-event-detail-value bfc-event-detail-color @BlazorFullCalendarHelpers.GetColorCss(Event.Color)">@ColorScheme.GetPrimaryLabel(Event.Color, Texts)</div>
                </div>
            </div>
            <div class="bfc-event-detail-row">
                <svg class="bfc-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                <div style="flex:1;min-width:0;">
                    <div class="bfc-event-detail-label">@Texts.AttendeesLabel</div>
                    @if (Event.Attendees.Count == 0)
                    {
                        <div class="bfc-event-detail-value" style="color:var(--bfc-text-muted);">@Texts.NoAttendeesText</div>
                    }
                    else
                    {
                        <div class="bfc-attendees-chips" style="margin-top:6px;">
                            @foreach (var a in Event.Attendees)
                            {
                                <span class="bfc-attendee-chip bfc-attendee-chip-readonly">
                                    <span class="bfc-attendee-chip-avatar">@a.Initials</span>
                                    @a.FullName
                                </span>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="bfc-event-detail-row">
                <svg class="bfc-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                <div>
                    <div class="bfc-event-detail-label">@Texts.StartDateLabel</div>
                    <div class="bfc-event-detail-value">
                        @Event.StartDate.ToString("dddd dd MMMM", State.Culture) @Texts.AtWord @BlazorFullCalendarHelpers.FormatTime(Event.StartDate, State.Use24HourFormat)
                    </div>
                </div>
            </div>
            <div class="bfc-event-detail-row">
                <svg class="bfc-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <div>
                    <div class="bfc-event-detail-label">@Texts.EndDateLabel</div>
                    <div class="bfc-event-detail-value">
                        @Event.EndDate.ToString("dddd dd MMMM", State.Culture) @Texts.AtWord @BlazorFullCalendarHelpers.FormatTime(Event.EndDate, State.Use24HourFormat)
                    </div>
                </div>
            </div>
            <div class="bfc-event-detail-row">
                <svg class="bfc-event-detail-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg>
                <div>
                    <div class="bfc-event-detail-label">@Texts.DescriptionLabel</div>
                    <div class="bfc-event-detail-value">@Event.Description</div>
                </div>
            </div>
        </div>
        <div class="bfc-dialog-footer" style="justify-content:space-between;">
            <button class="bfc-btn" @onclick="OnClose">@Texts.CloseButton</button>
            <div style="display:flex;gap:8px;">
                <button class="bfc-btn" @onclick="EditAsync">@Texts.EditButton</button>
                <button class="bfc-btn bfc-btn-danger" @onclick="Delete">@Texts.DeleteButton</button>
            </div>
        </div>
    </div>
</div>

@if (_showEdit)
{
    <AddEditEventDialog ExistingEvent="Event" OnClose="OnEditClose" />
}

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarTexts Texts { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarColorScheme ColorScheme { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarChangeNotifier Notifier { get; set; } = default!;
    [Parameter] public BlazorFullCalendarEvent Event { get; set; } = default!;
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _showEdit;

    private void EditAsync()
    {
        _showEdit = true;
    }

    private void OnEditClose()
    {
        _showEdit = false;
        OnClose.InvokeAsync();
    }

    private async Task Delete()
    {
        var snapshot = BlazorFullCalendarChangeNotifier.CloneEvent(Event);
        State.RemoveEvent(Event.Id);
        await Notifier.NotifyAsync(new BlazorFullCalendarChangeEventArgs
        {
            Event = snapshot,
            OldEvent = snapshot,
            Kind = BlazorFullCalendarChangeKind.Delete,
            Source = BlazorFullCalendarChangeSource.Delete
        });
        await OnClose.InvokeAsync();
    }
}


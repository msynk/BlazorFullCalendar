@namespace BlazorFullCalendar

<div class="cal-overlay" @onclick="OnClose">
    <div class="cal-dialog" @onclick:stopPropagation="true">
        <div class="cal-dialog-header cal-dialog-header-row">
            <div>
                <h3>@(_isEditing ? Texts.EditEventDialogTitle : Texts.AddEventDialogTitle)</h3>
                <p>@(_isEditing ? Texts.EditEventDialogSubtitle : Texts.AddEventDialogSubtitle)</p>
            </div>
            <button class="cal-dialog-close-btn" @onclick="OnClose" aria-label="@Texts.CloseAriaLabel">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="cal-dialog-body">
            <div class="cal-field">
                <label>@Texts.TitleLabel</label>
                <input type="text" @bind="_title" placeholder="@Texts.EventTitlePlaceholder" />
                @if (_errors.ContainsKey("title"))
                {
                    <div class="cal-field-error">@_errors["title"]</div>
                }
            </div>

            <div class="cal-field">
                <label>@Texts.StartDateTimeLabel</label>
                <DateTimePicker Value="_startDate" ValueChanged="OnStartDateChanged" Culture="State.Culture" />
            </div>

            <div class="cal-field">
                <label>@Texts.EndDateTimeLabel</label>
                <DateTimePicker Value="_endDate" ValueChanged="OnEndDateChanged" Culture="State.Culture" />
                @if (_errors.ContainsKey("endDate"))
                {
                    <div class="cal-field-error">@_errors["endDate"]</div>
                }
            </div>

            <div class="cal-field">
                <label>@Texts.ColorLabel</label>
                <select @bind="_color" aria-label="@Texts.EventColorAriaLabel">
                    @foreach (var opt in ColorScheme.GetEditorOptions(_isEditing ? _color : null))
                    {
                        <option value="@opt.Color">@ColorScheme.GetPrimaryLabel(opt.Color, Texts)</option>
                    }
                </select>
            </div>

            <div class="cal-field">
                <label>@Texts.DescriptionLabel</label>
                <textarea @bind="_description" placeholder="@Texts.EventDescriptionPlaceholder"></textarea>
                @if (_errors.ContainsKey("description"))
                {
                    <div class="cal-field-error">@_errors["description"]</div>
                }
            </div>

            <div class="cal-field">
                <label>@Texts.AttendeesLabel</label>
                @if (_attendees.Count > 0)
                {
                    <div class="cal-attendees-chips">
                        @foreach (var a in _attendees)
                        {
                            var attendee = a;
                            <span class="cal-attendee-chip">
                                <span class="cal-attendee-chip-avatar">@attendee.Initials</span>
                                @attendee.FullName
                                <button class="cal-attendee-chip-remove" type="button" @onclick="() => RemoveAttendee(attendee)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </span>
                        }
                    </div>
                }
                <div class="cal-attendee-add-row">
                    <input type="text" @bind="_newFirstName" placeholder="@Texts.FirstNamePlaceholder" />
                    <input type="text" @bind="_newLastName" placeholder="@Texts.LastNamePlaceholder" />
                    <input type="text" @bind="_newId" placeholder="@Texts.IdOptionalPlaceholder" />
                    <button class="cal-btn cal-btn-sm" type="button" @onclick="AddAttendee">@Texts.AddButton</button>
                </div>
                @if (_errors.ContainsKey("attendee"))
                {
                    <div class="cal-field-error">@_errors["attendee"]</div>
                }
            </div>
        </div>
        <div class="cal-dialog-footer">
            <button class="cal-btn" @onclick="OnClose">@Texts.CancelButton</button>
            <button class="cal-btn cal-btn-primary" @onclick="Submit">
                @(_isEditing ? Texts.SaveChangesButton : Texts.CreateEventButton)
            </button>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarTexts Texts { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarColorScheme ColorScheme { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarChangeNotifier Notifier { get; set; } = default!;
    [Parameter] public BlazorFullCalendarEvent? ExistingEvent { get; set; }
    [Parameter] public DateTime? StartDate { get; set; }
    [Parameter] public int? StartHour { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _isEditing;
    private string _title = "";
    private string _description = "";
    private DateTime _startDate;
    private DateTime _endDate;
    private BlazorFullCalendarEventColor _color;
    private List<BlazorFullCalendarAttendee> _attendees = [];
    private string _newFirstName = "";
    private string _newLastName = "";
    private string _newId = "";
    private Dictionary<string, string> _errors = new();

    protected override void OnInitialized()
    {
        _isEditing = ExistingEvent != null;
        var defaultColor = ColorScheme.Options[0].Color;

        if (_isEditing)
        {
            _title = ExistingEvent!.Title;
            _description = ExistingEvent.Description;
            _startDate = ExistingEvent.StartDate;
            _endDate = ExistingEvent.EndDate;
            _color = ExistingEvent.Color;
            _attendees = [.. ExistingEvent.Attendees];
        }
        else
        {
            _color = defaultColor;
            var baseDate = StartDate ?? State.SelectedDate;
            _startDate = baseDate.Date.AddHours(StartHour ?? DateTime.Now.Hour);
            _endDate = _startDate.AddMinutes(30);
        }
    }

    private void AddAttendee()
    {
        _errors.Remove("attendee");

        if (string.IsNullOrWhiteSpace(_newFirstName) && string.IsNullOrWhiteSpace(_newLastName))
        {
            _errors["attendee"] = Texts.ValidationAttendeeNameRequired;
            return;
        }

        _attendees.Add(new BlazorFullCalendarAttendee
        {
            FirstName = _newFirstName.Trim(),
            LastName = _newLastName.Trim(),
            Id = string.IsNullOrWhiteSpace(_newId) ? null : _newId.Trim()
        });

        _newFirstName = "";
        _newLastName = "";
        _newId = "";
    }

    private void RemoveAttendee(BlazorFullCalendarAttendee attendee) => _attendees.Remove(attendee);

    private Task OnStartDateChanged(DateTime value)
    {
        _startDate = value;
        return Task.CompletedTask;
    }

    private Task OnEndDateChanged(DateTime value)
    {
        _endDate = value;
        return Task.CompletedTask;
    }

    private async Task Submit()
    {
        _errors.Clear();
        if (string.IsNullOrWhiteSpace(_title))
            _errors["title"] = Texts.ValidationTitleRequired;
        if (string.IsNullOrWhiteSpace(_description))
            _errors["description"] = Texts.ValidationDescriptionRequired;
        if (_endDate <= _startDate)
            _errors["endDate"] = Texts.ValidationEndAfterStart;

        if (_errors.Count > 0) return;

        var oldSnapshot = _isEditing && ExistingEvent is not null
            ? BlazorFullCalendarChangeNotifier.CloneEvent(ExistingEvent)
            : null;

        var ev = new BlazorFullCalendarEvent
        {
            Id = _isEditing ? ExistingEvent!.Id : Random.Shared.Next(100000, 999999),
            Title = _title,
            Description = _description,
            StartDate = _startDate,
            EndDate = _endDate,
            Color = _color,
            Attendees = [.. _attendees]
        };

        if (_isEditing)
            State.UpdateEvent(ev);
        else
            State.AddEvent(ev);

        await Notifier.NotifyAsync(new BlazorFullCalendarChangeEventArgs
        {
            Event = BlazorFullCalendarChangeNotifier.CloneEvent(ev),
            OldEvent = oldSnapshot,
            Kind = _isEditing ? BlazorFullCalendarChangeKind.Edit : BlazorFullCalendarChangeKind.Add,
            Source = BlazorFullCalendarChangeSource.Dialog
        });

        await OnClose.InvokeAsync();
    }
}


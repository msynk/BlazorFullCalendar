@namespace BlazorFullCalendar

<div class="bfc-droppable @(_isOver ? "drag-over" : "") @Class"
     @ondragover="OnDragOver"
     @ondragover:preventDefault="true"
     @ondragleave="OnDragLeave"
     @ondrop="OnDrop">
    @ChildContent
</div>

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarChangeNotifier Notifier { get; set; } = default!;
    [Parameter] public DateTime Date { get; set; }
    [Parameter] public int? Hour { get; set; }
    [Parameter] public int? Minute { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private bool _isOver;

    private void OnDragOver() => _isOver = true;
    private void OnDragLeave() => _isOver = false;

    private async Task OnDrop()
    {
        _isOver = false;
        await Notifier.HandleDropAsync(Date, Hour, Minute);
    }
}


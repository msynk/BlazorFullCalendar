@namespace BlazorFullCalendar

<div class="bfc-dropdown">
    <button class="bfc-btn bfc-btn-icon bfc-btn-sm" @onclick="() => _open = !_open" title="@Texts.SettingsButtonTitle">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    </button>
    @if (_open)
    {
        <div class="bfc-dropdown-menu">
            <div class="bfc-dropdown-label">@Texts.CalendarSettingsLabel</div>

            <div class="bfc-dropdown-item" @onclick="State.ToggleDarkMode">
                <span>@Texts.DarkModeLabel</span>
                <label class="bfc-toggle">
                    <input type="checkbox" checked="@State.IsDarkMode" />
                    <span class="bfc-toggle-track"></span>
                    <span class="bfc-toggle-thumb"></span>
                </label>
            </div>

            <div class="bfc-dropdown-item" @onclick="() => State.SetBadgeVariant(State.BadgeVariant == BlazorFullCalendarBadgeVariant.Dot ? BlazorFullCalendarBadgeVariant.Colored : BlazorFullCalendarBadgeVariant.Dot)">
                <span>@Texts.DotBadgeLabel</span>
                <label class="bfc-toggle">
                    <input type="checkbox" checked="@(State.BadgeVariant == BlazorFullCalendarBadgeVariant.Dot)" />
                    <span class="bfc-toggle-track"></span>
                    <span class="bfc-toggle-thumb"></span>
                </label>
            </div>

            <div class="bfc-dropdown-item" @onclick="State.ToggleTimeFormat">
                <span>@Texts.TwentyFourHourFormatLabel</span>
                <label class="bfc-toggle">
                    <input type="checkbox" checked="@State.Use24HourFormat" />
                    <span class="bfc-toggle-track"></span>
                    <span class="bfc-toggle-thumb"></span>
                </label>
            </div>

            <div class="bfc-dropdown-sep"></div>

            <div class="bfc-dropdown-item">
                <span>@Texts.DayStartsAtLabel</span>
                <div style="display:flex;align-items:center;gap:4px;">
                    <input type="number" min="0" max="16" value="@State.StartOfDayHour"
                           @onchange="OnStartHourChange"
                           style="width:50px;padding:4px;font-size:12px;border:1px solid var(--bfc-border);border-radius:4px;background:var(--bfc-bg);color:var(--bfc-text);" />
                    <span style="font-size:12px;">@Texts.HourSuffix</span>
                </div>
            </div>

            <div class="bfc-dropdown-sep"></div>
            <div class="bfc-dropdown-label">@Texts.AgendaGroupByLabel</div>

            <div class="bfc-dropdown-item @(State.AgendaModeGroupBy == BlazorFullCalendarAgendaGroupBy.Date ? "active" : "")"
                 @onclick="() => State.SetAgendaModeGroupBy(BlazorFullCalendarAgendaGroupBy.Date)"
                 style="@(State.AgendaModeGroupBy == BlazorFullCalendarAgendaGroupBy.Date ? "background:var(--bfc-bg-hover);" : "")">
                @Texts.AgendaGroupByDate
            </div>
            <div class="bfc-dropdown-item @(State.AgendaModeGroupBy == BlazorFullCalendarAgendaGroupBy.Color ? "active" : "")"
                 @onclick="() => State.SetAgendaModeGroupBy(BlazorFullCalendarAgendaGroupBy.Color)"
                 style="@(State.AgendaModeGroupBy == BlazorFullCalendarAgendaGroupBy.Color ? "background:var(--bfc-bg-hover);" : "")">
                @Texts.AgendaGroupByColor
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarTexts Texts { get; set; } = default!;
    private bool _open;

    private void OnStartHourChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
            State.SetStartOfDayHour(val);
    }
}


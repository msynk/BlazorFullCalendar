@namespace BlazorFullCalendar

<div class="cal-filter-row">
    <select class="cal-filter-select" @onchange="HandleColorChange" value="@SelectedColorValue" aria-label="@Texts.FilterByColorAriaLabel">
        <option value="">@Texts.AllColorsOption</option>
        @foreach (var opt in ColorScheme.Options)
        {
            <option value="@opt.Color">@ColorScheme.GetPrimaryLabel(opt.Color, Texts)</option>
        }
    </select>

    <select class="cal-filter-select cal-filter-select-person" @onchange="HandleAttendeeChange" value="@(State.SelectedAttendeeKey ?? "")" aria-label="@Texts.FilterByPersonAriaLabel">
        <option value="">@Texts.AllPeopleOption</option>
        @foreach (var (key, name) in State.GetAttendeesInCurrentView(Texts.UnnamedAttendee))
        {
            <option value="@key">@name</option>
        }
    </select>
</div>

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarTexts Texts { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarColorScheme ColorScheme { get; set; } = default!;

    private string SelectedColorValue => State.SelectedColors.Count == 1
        ? State.SelectedColors[0].ToString()
        : string.Empty;

    private void HandleColorChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(value))
        {
            State.SetColorFilter(null);
            return;
        }

        if (Enum.TryParse<BlazorFullCalendarEventColor>(value, out var selected))
            State.SetColorFilter(selected);
    }

    private void HandleAttendeeChange(ChangeEventArgs e) =>
        State.SetAttendeeFilter(e.Value?.ToString());
}


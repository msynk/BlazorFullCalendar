@namespace BlazorFullCalendar

<div class="bfc-view-tabs">
    @foreach (var view in _views)
    {
        <button class="bfc-view-tab @(State.View == view ? "active" : "")"
                @onclick="() => State.SetView(view)">
            @Texts.GetViewLabel(view)
        </button>
    }
</div>

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;
    [CascadingParameter] public BlazorFullCalendarTexts Texts { get; set; } = default!;

    private static readonly BlazorFullCalendarView[] _views = [
        BlazorFullCalendarView.Day, BlazorFullCalendarView.Week, BlazorFullCalendarView.Month,
        BlazorFullCalendarView.Year, BlazorFullCalendarView.Agenda
    ];
}


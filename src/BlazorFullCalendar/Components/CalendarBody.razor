@namespace BlazorFullCalendar
@implements IDisposable

<div class="bfc-body" @key="State.View">
    @switch (State.View)
    {
        case BlazorFullCalendarView.Month:
            <CalendarMonthView SingleDayEvents="_singleDayEvents" MultiDayEvents="_multiDayEvents" EventTemplate="MonthEventTemplate" />
            break;
        case BlazorFullCalendarView.Week:
            <CalendarWeekView SingleDayEvents="_singleDayEvents" MultiDayEvents="_multiDayEvents" EventTemplate="WeekEventTemplate" />
            break;
        case BlazorFullCalendarView.Day:
            <CalendarDayView SingleDayEvents="_singleDayEvents" MultiDayEvents="_multiDayEvents" EventTemplate="DayEventTemplate" />
            break;
        case BlazorFullCalendarView.Year:
            <CalendarYearView SingleDayEvents="_singleDayEvents" MultiDayEvents="_multiDayEvents" />
            break;
        case BlazorFullCalendarView.Agenda:
            <AgendaEvents />
            break;
    }
</div>

@code {
    [CascadingParameter] public BlazorFullCalendarState State { get; set; } = default!;

    [Parameter] public RenderFragment<BlazorFullCalendarEvent>? MonthEventTemplate { get; set; }
    [Parameter] public RenderFragment<BlazorFullCalendarEvent>? WeekEventTemplate { get; set; }
    [Parameter] public RenderFragment<BlazorFullCalendarEvent>? DayEventTemplate { get; set; }

    private List<BlazorFullCalendarEvent> _singleDayEvents = [];
    private List<BlazorFullCalendarEvent> _multiDayEvents = [];

    protected override void OnInitialized()
    {
        State.OnStateChanged += Refresh;
        ComputeEvents();
    }

    private void Refresh()
    {
        ComputeEvents();
        InvokeAsync(StateHasChanged);
    }

    private void ComputeEvents()
    {
        _singleDayEvents = State.Events.Where(e => e.IsSingleDay).ToList();
        _multiDayEvents = State.Events.Where(e => e.IsMultiDay).ToList();
    }

    public void Dispose() => State.OnStateChanged -= Refresh;
}


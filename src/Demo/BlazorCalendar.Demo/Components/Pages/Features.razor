@page "/features"

<PageTitle>Features - Blazor Calendar</PageTitle>

<section class="demo-hero" style="padding-bottom:32px;">
    <div class="demo-hero-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Complete Feature List
    </div>
    <h1>Everything<br/>Out of the Box</h1>
    <p>
        A comprehensive calendar component that covers every feature you need for scheduling, event management, and team coordination.
    </p>
</section>

<!-- Feature Sections -->
<div style="max-width:900px;margin:0 auto;padding:0 24px 64px;">

    <!-- Views -->
    <div style="margin-bottom:48px;">
        <h2 style="font-size:22px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <span style="width:36px;height:36px;border-radius:10px;background:#eff6ff;color:#3b82f6;display:inline-flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            </span>
            Calendar Views
        </h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;">
            @foreach (var view in _views)
            {
                <div class="demo-feature-card" style="padding:16px;">
                    <h3 style="font-size:14px;margin-bottom:4px;">@view.Name</h3>
                    <p>@view.Desc</p>
                </div>
            }
        </div>
    </div>

    <!-- Event Management -->
    <div style="margin-bottom:48px;">
        <h2 style="font-size:22px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <span style="width:36px;height:36px;border-radius:10px;background:#fef3c7;color:#d97706;display:inline-flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </span>
            Event Management
        </h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;">
            @foreach (var feat in _eventFeatures)
            {
                <div class="demo-feature-card" style="padding:16px;">
                    <h3 style="font-size:14px;margin-bottom:4px;">@feat.Name</h3>
                    <p>@feat.Desc</p>
                </div>
            }
        </div>
    </div>

    <!-- Interactions -->
    <div style="margin-bottom:48px;">
        <h2 style="font-size:22px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <span style="width:36px;height:36px;border-radius:10px;background:#f0fdf4;color:#16a34a;display:inline-flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            </span>
            Interactions
        </h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;">
            @foreach (var feat in _interactions)
            {
                <div class="demo-feature-card" style="padding:16px;">
                    <h3 style="font-size:14px;margin-bottom:4px;">@feat.Name</h3>
                    <p>@feat.Desc</p>
                </div>
            }
        </div>
    </div>

    <!-- Theming & Settings -->
    <div style="margin-bottom:48px;">
        <h2 style="font-size:22px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <span style="width:36px;height:36px;border-radius:10px;background:#fdf2f8;color:#db2777;display:inline-flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            </span>
            Theming &amp; Settings
        </h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;">
            @foreach (var feat in _theming)
            {
                <div class="demo-feature-card" style="padding:16px;">
                    <h3 style="font-size:14px;margin-bottom:4px;">@feat.Name</h3>
                    <p>@feat.Desc</p>
                </div>
            }
        </div>
    </div>

    <!-- Architecture -->
    <div style="margin-bottom:48px;">
        <h2 style="font-size:22px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
            <span style="width:36px;height:36px;border-radius:10px;background:#faf5ff;color:#9333ea;display:inline-flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </span>
            Architecture
        </h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:12px;">
            @foreach (var feat in _architecture)
            {
                <div class="demo-feature-card" style="padding:16px;">
                    <h3 style="font-size:14px;margin-bottom:4px;">@feat.Name</h3>
                    <p>@feat.Desc</p>
                </div>
            }
        </div>
    </div>

    <!-- CTA -->
    <div style="text-align:center;padding:32px 0;">
        <a href="/demo" class="demo-btn demo-btn-primary" style="font-size:15px;padding:14px 32px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Try the Live Demo
        </a>
    </div>
</div>

<footer class="demo-footer">
    <p>
        Blazor Calendar &mdash; A port of
        <a href="https://github.com/yassir-jeraidi/full-calendar" target="_blank">yassir-jeraidi/full-calendar</a>
        to Blazor/.NET
    </p>
</footer>

@code {
    private record FeatureItem(string Name, string Desc);

    private static readonly FeatureItem[] _views =
    [
        new("Month View", "Classic grid layout with 7-column day headers, multi-day event spanning, up to 3 visible events per cell with '+N more' overflow."),
        new("Week View", "7-day time grid with 24-hour rows, overlapping event columns, multi-day events row, and current-time indicator."),
        new("Day View", "Single-day time grid with sidebar mini-calendar, 'Happening Now' panel, and detailed hourly slots."),
        new("Year View", "12-month overview grid (4x3) with colored event bullets. Click a day to see events, click month name to navigate."),
        new("Agenda View", "Searchable list of events for the current month. Group by date or color. Quick overview of everything scheduled."),
    ];

    private static readonly FeatureItem[] _eventFeatures =
    [
        new("Create Events", "Click any empty time slot or use the 'Add Event' button. Form with title, description, date-time pickers, and color selection."),
        new("Edit Events", "Open any event's details dialog and click Edit. All fields are pre-filled for quick modifications."),
        new("Delete Events", "Remove events with a single click from the details dialog. Immediate UI update."),
        new("Color Coding", "6 distinct colors (Blue, Green, Red, Yellow, Purple, Orange) with matching light/dark theme variants."),
        new("Multi-Day Events", "Events spanning multiple days render as connected badges across day cells with first/middle/last visual states."),
        new("Form Validation", "Required fields (title, description) and date range validation (end must be after start) with inline error messages."),
    ];

    private static readonly FeatureItem[] _interactions =
    [
        new("Drag & Drop", "Move events between dates in month view, or between time slots in day/week views. Events preserve their duration."),
        new("Drop Zone Feedback", "Visual highlighting of valid drop targets when dragging an event, making it clear where it will land."),
        new("Resize Handles", "Top and bottom resize handles on event blocks in day/week views for adjusting start or end times."),
        new("Click-to-Create", "Click any empty hour slot in day/week view to open the add-event dialog pre-filled with that time."),
    ];

    private static readonly FeatureItem[] _theming =
    [
        new("Dark Mode", "Full dark theme with CSS custom properties. Toggle from the settings gear icon. All colors adapt automatically."),
        new("12/24-Hour Format", "Switch between 24-hour (14:00) and 12-hour (2:00 PM) time display throughout the entire calendar."),
        new("Badge Variants", "Choose between colored badges (full event color background) or dot badges (neutral background with colored dot indicator)."),
        new("Start-of-Day Hour", "Configure which hour the day/week views scroll to on load (default 8:00). Range 0-16."),
        new("Agenda Grouping", "Group agenda view events by date (chronological) or by color (categorical). Toggle in settings."),
        new("Responsive Design", "Adapts to mobile screens — header stacks vertically, sidebar hides, year grid becomes 2 columns."),
    ];

    private static readonly FeatureItem[] _architecture =
    [
        new("CascadingValue State", "Central CalendarState passed via CascadingValue. All child components react to state changes automatically."),
        new("40+ Razor Components", "Modular architecture with single-responsibility components organized in a clear folder structure."),
        new("Pure C# Helpers", "All date math ported to C# — no date-fns dependency. Static CalendarHelpers class with 20+ utility methods."),
        new("CSS Custom Properties", "Theming via CSS variables makes it easy to customize colors without touching component code."),
        new("Zero JS Frameworks", "Built entirely in Blazor with minimal JS interop only for browser APIs (resize, localStorage, matchMedia)."),
        new("WebAssembly Ready", "Runs as Blazor WebAssembly for client-side interactivity. No server roundtrip for UI interactions."),
    ];
}
